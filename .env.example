# --- Meritsync Local Environment Template ---

# 1. Supabase (Database & Auth)
# Get these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key

# 2. Google AI (Gemini 1.5 Flash)
# Get this from https://aistudio.google.com/
GOOGLE_AI_API_KEY=your-google-ai-api-key

# 3. Scraper Internal Auth
# A secure string used to authenticate the Python service to the Next.js API
SCRAPER_SERVICE_KEY=generate-a-secure-random-string
